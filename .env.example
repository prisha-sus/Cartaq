# ============================================================
# CARTAQ — Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  copy .env.example .env   (Windows)
#                    OR  cp .env.example .env     (Mac/Linux)
#   2. Fill in the values you need below
#   3. Never commit .env to git (it is already in .gitignore)
# ============================================================


# ── Role 1: OpenAQ (Air Quality Data) ────────────────────────
# Free key from: https://explore.openaq.org/register
# Without this, OpenAQ ingestion returns empty data
OPENAQ_API_KEY=


# ── Role 1: NASA FIRMS (Fire / Thermal Anomaly Data) ─────────
# Free key from: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Without this, FIRMS ingestion returns empty data
NASA_FIRMS_MAP_KEY=


# ── Role 4: Twilio (Automated Voice Calls) ───────────────────
# Get from: https://console.twilio.com
# Leave blank (or TWILIO_DRY_RUN=true) to run in safe dry-run mode
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15005550006
TWILIO_TO_NUMBER=
TWILIO_DRY_RUN=true


# ── Role 4: IndicTrans2 Translation (Hindi / Marathi) ────────
# Free account + token from: https://huggingface.co/settings/tokens
# Then request model access at:
# https://huggingface.co/ai4bharat/indictrans2-en-indic-1B
# Without this, translations show placeholder text (pipeline still runs)
HUGGINGFACE_TOKEN=


# ── Role 4: MQTT (Eclipse Mosquitto) ─────────────────────────
# Set to false only after running: docker compose -f infra/docker-compose.yml up -d
MQTT_DRY_RUN=true
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=


# ── Role 3: ClickHouse (optional override) ───────────────────
# Only needed if you changed the defaults in docker-compose.yml
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=cartaq
CLICKHOUSE_USER=cartaq_user
CLICKHOUSE_PASSWORD=cartaq_pass


# ── Role 3 / 4: PostGIS (optional override) ──────────────────
POSTGIS_DSN=host=localhost port=5432 dbname=cartaq user=cartaq_user password=cartaq_pass


# ── AQI Alert Threshold ───────────────────────────────────────
# Hexes with predicted AQI above this value trigger dispatch alerts
AQI_ALERT_THRESHOLD=150
